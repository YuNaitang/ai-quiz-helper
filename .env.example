# ── API 服务商配置 ──────────────────────────────────────
# 预设：deepseek / openai / openrouter / siliconflow / custom
# API_PROVIDER=deepseek

# API Key（向后兼容 DEEPSEEK_API_KEY）
API_KEY=your_real_api_key_here

# 以下为可选覆盖项（不设置则使用预设默认值）
# API_BASE_URL=https://api.deepseek.com/v1
# API_MODEL=deepseek-chat
# API_AUTH_SCHEME=Bearer
# API_EXTRA_HEADERS={"X-Custom-Header":"value"}

# ── PostgreSQL 缓存配置（可选，不设置则跳过缓存）──────────
# DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_tiku_cache
# Cache TTL in seconds (default 24 hours)
# DB_CACHE_TTL_SECONDS=86400
